{
  "name": "@agentkitai/agentlens-server",
  "version": "0.21.0",
  "description": "AgentLens API server — event ingestion, querying, dashboard, and alerting for AI agents",
  "type": "module",
  "license": "MIT",
  "author": "Amit Paz",
  "repository": {
    "type": "git",
    "url": "https://github.com/agentkitai/agentlens.git",
    "directory": "packages/server"
  },
  "homepage": "https://github.com/agentkitai/agentlens",
  "bugs": {
    "url": "https://github.com/agentkitai/agentlens/issues"
  },
  "keywords": [
    "agentlens",
    "ai-agents",
    "observability",
    "api-server",
    "event-sourcing",
    "audit-trail",
    "hono",
    "sqlite",
    "dashboard",
    "mcp"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc && cp -r src/db/drizzle dist/db/drizzle",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "dev": "tsx watch src/index.ts",
    "benchmark:postgres": "tsx scripts/benchmark-postgres.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate"
  },
  "dependencies": {
    "@agentkitai/agentlens-core": "workspace:*",
    "@agentkitai/auth": "workspace:*",
    "@aws-sdk/client-s3": "^3.1076.0",
    "@azure/storage-blob": "^12.33.0",
    "@google-cloud/storage": "^7.21.0",
    "@hono/node-server": "^1.19.10",
    "@hono/zod-openapi": "^1.4.0",
    "@node-saml/node-saml": "^5.1.0",
    "@scalar/hono-api-reference": "^0.11.8",
    "better-sqlite3": "^12.11.1",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.27",
    "hono-rate-limiter": "^0.5.3",
    "jose": "^6.0.11",
    "node-forge": "^1.4.0",
    "obscenity": "^0.4.6",
    "postgres": "^3.4.8",
    "protobufjs": "^8.6.6",
    "ulid": "^3.0.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node-forge": "^1.3.14",
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^0.31.9",
    "pg": "^8.22.0"
  }
}
